import { useState } from 'react'
import { useNavigate, Link } from 'react-router-dom'
import { useDashboardStore } from '../store/dashboardStore.jsx'

export default function CreateCollectionCenter() {
  const navigate = useNavigate()
  const {
    partners = [],
    centers = [],
    addCenter
  } = useDashboardStore()
  const [activeTab, setActiveTab] = useState('create')

  const handleSubmit = (e) => {
    e.preventDefault()
    const fd = new FormData(e.target)
    addCenter({
      partnerId: fd.get('center_partnerId') || '',
      name: fd.get('center_name') || '',
      city: fd.get('center_city') || '',
      address: fd.get('center_address') || '',
      slots: Number(fd.get('center_slots')) || 0,
    })
    setActiveTab('view')
  }

  const getPartnerName = (partnerId) => partners.find((p) => p.id === partnerId)?.name || '—'

  return (
    <>
      <header className="main-header">
        <h2 className="page-title">Center Management</h2>
        <p className="page-desc">Create new centers or view existing collection centers.</p>
      </header>
      <div className="content">
        <section className="panel">
          {/* Tabs */}
          <div className="panel-tabs">
            <button
              type="button"
              className={`panel-tab ${activeTab === 'create' ? 'active' : ''}`}
              onClick={() => setActiveTab('create')}
            >
              Create Center
            </button>
            <button
              type="button"
              className={`panel-tab ${activeTab === 'view' ? 'active' : ''}`}
              onClick={() => setActiveTab('view')}
            >
              View Centers {centers.length > 0 && `(${centers.length})`}
            </button>
          </div>

          {/* Create Tab */}
          {activeTab === 'create' && (
            <div style={{ padding: '1.25rem 1.5rem' }}>
              <form className="form form-modal" onSubmit={handleSubmit} autoComplete="off">
                <div className="form-section">
                  <div className="form-row form-row-2">
                    <label>Center name <input name="center_name" type="text" placeholder="e.g. Central Hub" required /></label>
                    <label>Partner <select name="center_partnerId" required><option value="">Select partner</option>{partners.filter(p => p.partnerType !== 'organization').map(p => <option key={p.id} value={p.id}>{p.name}</option>)}</select></label>
                  </div>
                  <div className="form-row form-row-2">
                    <label>City <input name="center_city" type="text" placeholder="e.g. Mumbai" required /></label>
                    <label>Slots <input name="center_slots" type="number" placeholder="120" min={1} required /></label>
                  </div>
                  <div className="form-row form-row-1">
                    <label>Address <input name="center_address" type="text" placeholder="Full address" required /></label>
                  </div>
                </div>
                <div className="form-section-actions" style={{ marginTop: '1.5rem', display: 'flex', gap: '0.75rem' }}>
                  <button type="submit" className="btn-primary">Create Center</button>
                  <button type="button" className="btn-secondary" onClick={() => navigate('/dashboard?tab=partners')}>Cancel</button>
                </div>
              </form>
            </div>
          )}

          {/* View Tab */}
          {activeTab === 'view' && (
            <div>
              {centers.length === 0 ? (
                <div style={{ padding: '3rem', textAlign: 'center', color: 'var(--text-muted)' }}>
                  <div style={{ fontSize: '2.5rem', marginBottom: '0.75rem' }}>🏢</div>
                  <p>No centers found. Create your first center using the Create Center tab.</p>
                </div>
              ) : (
                <div className="table-wrap">
                  <table>
                    <thead>
                      <tr>
                        <th>Center ID</th>
                        <th>Center Name</th>
                        <th>Partner</th>
                        <th>City</th>
                        <th>Address</th>
                        <th>Slots</th>
                        <th>Actions</th>
                      </tr>
                    </thead>
                    <tbody>
                      {centers.map(c => (
                        <tr key={c.id}>
                          <td>
                            <Link
                              to={`/dashboard/tests/mapping?partnerId=${c.partnerId}&centerId=${c.id}`}
                              style={{ color: 'var(--primary)', textDecoration: 'none', fontWeight: 500 }}
                              title="Map tests to this center"
                            >
                              {c.id}
                            </Link>
                          </td>
                          <td><strong>{c.name}</strong></td>
                          <td>{getPartnerName(c.partnerId)}</td>
                          <td>{c.city}</td>
                          <td>{c.address}</td>
                          <td>{c.slots}</td>
                          <td>
                            <Link
                              to={`/dashboard/tests/mapping?partnerId=${c.partnerId}&centerId=${c.id}`}
                              className="action-icon"
                              title="Map tests to this center"
                            >
                              🗺️
                            </Link>
                            <Link
                              to={`/dashboard/slots/config?centerId=${c.id}`}
                              className="action-icon"
                              title="Configure slots"
                            >
                              📅
                            </Link>
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              )}
            </div>
          )}
        </section>
      </div>
    </>
  )
}
