/* MedPlus B2B theme: split layout with MedPlus red theme */
:root {
  --login-accent: rgb(191, 0, 39);
  --login-accent-hover: rgb(153, 0, 31);
  --login-accent-light: rgb(252, 238, 244);
  --login-panel-bg: linear-gradient(180deg, rgb(65, 0, 7) 0%, rgb(95, 0, 15) 100%);
}

.login-page {
  position: fixed;
  inset: 0;
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 100vh;
  box-sizing: border-box;
}

.login-panel {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 2rem 3rem;
}

.login-panel--left {
  background: var(--login-panel-bg);
  color: #fff;
}

.login-panel--right {
  background: #f8fafc;
  overflow: auto;
}

.login-brand-block {
  text-align: center;
  max-width: 360px;
}

.login-brand-block .logo-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 64px;
  height: 64px;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  font-weight: 700;
  font-size: 1.5rem;
  border-radius: 16px;
  margin-bottom: 1.5rem;
  backdrop-filter: blur(8px);
}

.login-brand-block h1 {
  margin: 0 0 0.5rem 0;
  font-size: 1.75rem;
  font-weight: 600;
  color: #fff;
  letter-spacing: -0.02em;
}

.login-brand-block .login-tagline {
  margin: 0;
  font-size: 1rem;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.5;
}

.login-form-wrap {
  width: 100%;
  max-width: 400px;
}

.login-card {
  background: #fff;
  border-radius: 16px;
  padding: 2.5rem;
  width: 100%;
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.06), 0 10px 20px -5px rgba(0, 0, 0, 0.08);
  border: 1px solid #e2e8f0;
}

.login-choice-card {
  max-width: 420px;
}

.login-brand {
  margin-bottom: 1.75rem;
}

.login-brand .logo-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 48px;
  height: 48px;
  background: var(--login-accent);
  color: white;
  font-weight: 700;
  font-size: 1.125rem;
  border-radius: 12px;
  margin-bottom: 0.75rem;
}

.login-brand h1 {
  margin: 0 0 0.25rem 0;
  font-size: 1.375rem;
  font-weight: 600;
  color: #0f172a;
}

.login-subtitle {
  margin: 0;
  font-size: 0.9375rem;
  color: #64748b;
}

.login-options {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
}

.login-option {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 0.35rem;
  padding: 1.25rem;
  border: 2px solid #e2e8f0;
  border-radius: 12px;
  text-decoration: none;
  color: inherit;
  background: #fff;
  transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
}

.login-option:hover {
  border-color: var(--login-accent);
  background: var(--login-accent-light);
  box-shadow: 0 2px 8px rgba(191, 0, 39, 0.12);
}

.login-option-icon {
  font-size: 1.5rem;
  margin-bottom: 0.25rem;
}

.login-option strong {
  font-size: 1rem;
  color: #0f172a;
}

.login-form label {
  display: block;
  margin-bottom: 1rem;
  font-size: 0.875rem;
  font-weight: 500;
  color: #334155;
}

.login-form input {
  display: block;
  width: 100%;
  margin-top: 0.35rem;
  padding: 0.75rem 1rem;
  border-radius: 10px;
  border: 1px solid #e2e8f0;
  font-size: 0.9375rem;
}

.login-form input:focus {
  outline: none;
  border-color: var(--login-accent);
  box-shadow: 0 0 0 3px rgba(191, 0, 39, 0.2);
}

.login-error {
  background: #fef2f2;
  color: #b91c1c;
  padding: 0.625rem 0.875rem;
  border-radius: 10px;
  font-size: 0.875rem;
  margin-bottom: 1rem;
}

.btn-login {
  width: 100%;
  padding: 0.75rem 1rem;
  margin-top: 0.25rem;
  background: var(--login-accent);
  color: white;
  font-weight: 600;
  border-radius: 10px;
  font-size: 0.9375rem;
  transition: background 0.2s;
}

.btn-login:hover:not(:disabled) {
  background: var(--login-accent-hover);
}

.btn-login:disabled {
  opacity: 0.7;
  cursor: not-allowed;
}

.btn-link {
  background: none;
  color: var(--login-accent);
  padding: 0.5rem;
  margin-top: 0.5rem;
  font-size: 0.875rem;
}

.btn-link:hover {
  text-decoration: underline;
}

.login-back {
  display: block;
  text-align: center;
  margin-top: 1.25rem;
  font-size: 0.875rem;
  color: #64748b;
  text-decoration: none;
}

.login-back:hover {
  color: var(--login-accent);
}

.login-hint {
  font-size: 0.75rem;
  color: #64748b;
  margin: 1rem 0 0 0;
  padding-top: 1rem;
  border-top: 1px solid #e2e8f0;
}

.login-otp-sent {
  font-size: 0.875rem;
  color: #64748b;
  margin: 0 0 1rem 0;
}

.login-otp-sent strong {
  color: #334155;
}

.login-resend {
  display: block;
  text-align: center;
  margin-top: 0.75rem;
  font-size: 0.875rem;
  color: #64748b;
}

@media (max-width: 768px) {
  .login-page {
    grid-template-columns: 1fr;
    grid-template-rows: auto 1fr;
  }

  .login-panel--left {
    padding: 2rem 1.5rem;
    min-height: 200px;
  }

  .login-brand-block h1 {
    font-size: 1.5rem;
  }

  .login-panel--right {
    padding: 1.5rem;
  }

  .login-options {
    grid-template-columns: 1fr;
  }

  .login-choice-card,
  .login-card {
    padding: 1.5rem 1.5rem;
  }
}
