export const useDashboardStore = create(
  persist(
    (set) => ({
      partners: initialPartners,
      clients: initialClients,
      centers: initialCenters,
      benefits: initialBenefits,
      packages: initialPackages,
      organizationSummaries: initialOrganizationSummaries,
      hrUsers: initialHrUsers,
      subscriptionRecords: initialSubscriptionRecords,

      addPartner: (partner) =>
        set((s) => ({
          partners: [...s.partners, { ...partner, id: partner.id || 'p' + Date.now() }],
        })),

      addClient: (client) =>
        set((s) => ({
          clients: [...s.clients, { ...client, id: client.id || 'c' + Date.now() }],
        })),

      addCenter: (center) =>
        set((s) => ({
          centers: [...s.centers, { ...center, id: center.id || 'cc' + Date.now() }],
        })),

      addBenefit: (benefit) =>
        set((s) => ({
          benefits: [...s.benefits, { ...benefit, id: benefit.id || 'b' + Date.now() }],
        })),

      addPackage: (pkg) =>
        set((s) => ({
          packages: [...s.packages, { ...pkg, id: pkg.id || 'pk' + Date.now() }],
        })),
    }),
    { name: 'bd-dashboard-store' }
  )
)
